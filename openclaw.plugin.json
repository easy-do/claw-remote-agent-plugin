{
  "id": "claw-remote-agent-plugin",
  "name": "远程客户端代理插件",
  "description": "远程设备管理插件，支持命令执行、系统监控、文件读写等功能",
  "version": "1.1.0",
  "channels": [],
  "skills": [],
  "configSchema": {
    "type": "object",
    "properties": {
      "port": {
        "type": "number",
        "default": 8765,
        "description": "WebSocket 服务端口"
      },
      "host": {
        "type": "string",
        "default": "0.0.0.0",
        "description": "WebSocket 服务监听地址"
      },
      "token": {
        "type": "string",
        "description": "认证令牌（必填）"
      },
      "unixSocket": {
        "type": "boolean",
        "default": true,
        "description": "是否启用 Unix Socket 实时通信"
      },
      "unixSocketPath": {
        "type": "string",
        "default": "/tmp/claw-remote-agent-plugin.sock",
        "description": "Unix Socket 文件路径"
      }
    },
    "required": ["token"]
  }
}
